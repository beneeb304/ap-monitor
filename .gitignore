# Local configuration (contains your network's IPs/hosts) — copy from config.example.yaml
# Anchored to repo root so it does NOT match addon/config.yaml (the HA manifest).
/config.yaml

# Runtime data
history.db
history.db-wal
history.db-shm
*.log

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# macOS Finder metadata
.DS_Store

# SSH keys must never be committed
ap_monitor
ap_monitor.pub
*.pem

# Pinned SSH host keys (per-network, created next to db_file at runtime)
/known_hosts
